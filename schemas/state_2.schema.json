{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "state_2",
  "description": "Artifact at end of stage DRIFT. Loaded by stage REFACTOR.",
  "type": "object",
  "required": [
    "schema_version",
    "phase_completed",
    "cycle_depth",
    "entropy_field",
    "operation_log"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "phase_completed": { "const": "DRIFT" },
    "cycle_depth": { "type": "integer", "minimum": 0 },
    "entropy_field": {
      "type": "object",
      "required": ["candidates", "tension_pairs", "failure_residue", "fluency_index", "flexibility_index"],
      "properties": {
        "candidates": {
          "type": "array",
          "minItems": 10,
          "items": {
            "type": "object",
            "required": ["proposition", "source"],
            "properties": {
              "proposition":         { "type": "string", "pattern": "^.{3,}\\s*×\\s*.{3,}\\s*→\\s*.{3,}$" },
              "domain":              { "type": "string" },
              "source":              { "enum": ["remote_associate", "constraint_relaxation", "constraint_inversion", "cross_domain", "analogical"] },
              "relaxed_constraint":  { "type": ["string", "null"] },
              "inverted_constraint": { "type": ["string", "null"] }
            }
          }
        },
        "tension_pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["a", "b", "tension_score"],
            "properties": {
              "a":             { "type": "string" },
              "b":             { "type": "string" },
              "tension_score": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "failure_residue": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["proposition", "source"],
            "properties": {
              "proposition": { "type": "string" },
              "source":      { "const": "failure_residue" }
            }
          }
        },
        "fluency_index":     { "type": "integer", "minimum": 10 },
        "flexibility_index": { "type": "integer", "minimum": 2 }
      }
    },
    "operation_log": {
      "type": "array",
      "minItems": 20,
      "maxItems": 150,
      "items": {
        "type": "object",
        "required": ["op", "notes", "timestamp"],
        "properties": {
          "op":        { "type": "string" },
          "notes":     { "type": "string" },
          "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" }
        }
      }
    }
  }
}
